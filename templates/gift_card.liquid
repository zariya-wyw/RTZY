<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'gift_cards.issued.title' | t }} | {{ shop.name }}</title>
  
  {{ 'zariya-styles.css' | asset_url | stylesheet_tag }}
  {{ 'zariya-shopify.css' | asset_url | stylesheet_tag }}
  
  <style>
    .gift-card-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      background: var(--bg);
    }
    .gift-card-container {
      max-width: 400px;
      text-align: center;
    }
    .gift-card-image {
      margin-bottom: 24px;
    }
    .gift-card-image img {
      max-width: 100%;
      border-radius: var(--radius-xl);
    }
    .gift-card-title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 2rem;
      margin: 0 0 8px;
    }
    .gift-card-amount {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--accent);
      margin: 16px 0;
    }
    .gift-card-code {
      background: var(--panel);
      padding: 16px 24px;
      border-radius: var(--radius-lg);
      font-family: monospace;
      font-size: 1.2rem;
      letter-spacing: 0.1em;
      margin: 24px 0;
      word-break: break-all;
    }
    .gift-card-instructions {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 24px;
    }
    .gift-card-qr {
      margin: 24px auto;
    }
    .gift-card-qr img {
      margin: 0 auto;
    }
    .gift-card-actions {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
  <div class="gift-card-page">
    <div class="gift-card-container">
      <div class="gift-card-image">
        <img src="{{ 'gift-card/card.svg' | shopify_asset_url }}" alt="Gift card">
      </div>
      
      <p class="eyebrow">{{ shop.name }}</p>
      <h1 class="gift-card-title">Gift Card</h1>
      
      <p class="gift-card-amount">{{ gift_card.balance | money }}</p>
      
      <div class="gift-card-code" id="gift-card-code">
        {{ gift_card.code | format_code }}
      </div>
      
      <p class="gift-card-instructions">
        Use this code at checkout to redeem your gift card.
      </p>
      
      {% if gift_card.expires_on %}
        <p class="gift-card-expiry">
          Expires on {{ gift_card.expires_on | date: "%B %d, %Y" }}
        </p>
      {% endif %}
      
      <div class="gift-card-qr">
        {{ gift_card.qr_code }}
      </div>
      
      <div class="gift-card-actions">
        <button class="button button-solid" onclick="copyCode()">Copy Code</button>
        <a href="{{ shop.url }}" class="button button-ghost">Shop Now</a>
      </div>
    </div>
  </div>
  
  <script>
    function copyCode() {
      const code = document.getElementById('gift-card-code').textContent.trim();
      navigator.clipboard.writeText(code).then(() => {
        alert('Gift card code copied!');
      });
    }
  </script>
</body>
</html>
