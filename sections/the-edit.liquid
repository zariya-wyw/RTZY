<section class="section" id="the-edit">
  <div class="container section-head">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <a class="text-link" href="{{ section.settings.view_all_link | default: routes.all_products_collection_url }}">{{ section.settings.link_text }} →</a>
  </div>
  <div class="container">
    <div class="slider-wrapper">
      <button class="slider-arrow slider-arrow-left is-hidden" type="button" data-slider="edit-grid" data-dir="left" aria-label="Scroll left">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div id="edit-grid" class="product-slider">
        {% assign edit_collection = collections[section.settings.collection] | default: collections.all %}
        {% for product in edit_collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
      <button class="slider-arrow slider-arrow-right" type="button" data-slider="edit-grid" data-dir="right" aria-label="Scroll right">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  const arrows = document.querySelectorAll('[data-slider="edit-grid"]');
  const slider = document.getElementById('edit-grid');
  if (!arrows.length || !slider) return;

  function updateArrowVisibility() {
    const leftArrow = document.querySelector('[data-slider="edit-grid"][data-dir="left"]');
    const rightArrow = document.querySelector('[data-slider="edit-grid"][data-dir="right"]');
    if (!leftArrow || !rightArrow) return;

    const scrollLeft = slider.scrollLeft;
    const maxScroll = slider.scrollWidth - slider.clientWidth;

    leftArrow.classList.toggle('is-hidden', scrollLeft <= 10);
    rightArrow.classList.toggle('is-hidden', scrollLeft >= maxScroll - 10);
  }

  slider.addEventListener('scroll', updateArrowVisibility, { passive: true });
  setTimeout(updateArrowVisibility, 500);
  window.addEventListener('resize', updateArrowVisibility, { passive: true });

  arrows.forEach(arrow => {
    arrow.addEventListener('click', () => {
      const card = slider.querySelector('.product-card');
      const cardWidth = card ? card.offsetWidth : 280;
      const scrollAmount = cardWidth + 20;
      const direction = arrow.dataset.dir;
      const newPosition = direction === 'left' 
        ? slider.scrollLeft - scrollAmount 
        : slider.scrollLeft + scrollAmount;
      
      slider.scrollTo({ left: newPosition, behavior: 'smooth' });
    });
  });
})();
</script>

{% schema %}
{
  "name": "The Edit",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The edit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pieces with stronger contrast."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Shop hoodies"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "The Edit"
    }
  ]
}
{% endschema %}
