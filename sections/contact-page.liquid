<section class="section contact-hero">
  <div class="container contact-hero-grid">
    <div class="reveal">
      <p class="eyebrow">Support</p>
      <h1>{{ section.settings.heading }}</h1>
      <p class="hero-text">{{ section.settings.subheading }}</p>
    </div>
    <article class="panel reveal">
      <p class="eyebrow">Contact channels</p>
      <div class="support-links" id="support">
        {% if section.settings.whatsapp %}
          <a href="https://wa.me/{{ section.settings.whatsapp }}" target="_blank" rel="noreferrer">WhatsApp support</a>
        {% endif %}
        {% if section.settings.email %}
          <a href="mailto:{{ section.settings.email }}">Email support</a>
        {% endif %}
        {% if section.settings.instagram %}
          <a href="{{ section.settings.instagram }}" target="_blank" rel="noreferrer">Instagram DM</a>
        {% endif %}
      </div>
      <p>Responses are quickest on WhatsApp during business hours.</p>
    </article>
  </div>
</section>

<section class="section">
  <div class="container contact-layout">
    {% form 'contact', class: 'contact-form panel reveal' %}
      <p class="eyebrow">Write to us</p>
      {% if form.posted_successfully? %}
        <p class="form-success">Thank you! We'll get back to you shortly.</p>
      {% endif %}
      <div class="field-grid">
        <label class="field">
          <span>Name</span>
          <input type="text" name="contact[name]" placeholder="Your name" required>
        </label>
        <label class="field">
          <span>Email</span>
          <input type="email" name="contact[email]" placeholder="Your email" required>
        </label>
      </div>
      <div class="field-grid">
        <label class="field">
          <span>Phone</span>
          <input type="tel" name="contact[phone]" placeholder="Phone number">
        </label>
        <label class="field">
          <span>Topic</span>
          <select name="contact[topic]">
            <option>Order help</option>
            <option>Size advice</option>
            <option>Returns</option>
            <option>Press / collab</option>
          </select>
        </label>
      </div>
      <label class="field">
        <span>Message</span>
        <textarea name="contact[body]" rows="7" placeholder="Tell us what you need" required></textarea>
      </label>
      <button class="button button-solid" type="submit">Send message</button>
    {% endform %}
    <aside class="contact-side reveal">
      <article class="panel">
        <p class="eyebrow">What happens next</p>
        <p>Our support team will review your inquiry and respond within 24 hours via your preferred contact method.</p>
      </article>
      <article class="panel">
        <p class="eyebrow">Support hours</p>
        <p>{{ section.settings.support_hours }}</p>
      </article>
    </aside>
  </div>
</section>

<section class="section" id="faq">
  <div class="container section-head">
    <div>
      <p class="eyebrow">FAQ</p>
      <h2>Questions we hear often.</h2>
    </div>
  </div>
  <div class="container faq-grid">
    {% for block in section.blocks %}
      <article class="panel reveal faq-item-open" {{ block.shopify_attributes }}>
        <h3 class="faq-question">{{ block.settings.question }}</h3>
        <p class="faq-answer">{{ block.settings.answer }}</p>
      </article>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need sizing help, order help, or a faster answer?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Reach out via the form below, WhatsApp, or email — our team typically responds within a few hours during business days."
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number",
      "default": "916399008999"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "zariya.wyw@gmail.com"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "support_hours",
      "label": "Support hours",
      "default": "Mon-Sat, 10:00 AM to 7:00 PM IST"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Page",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How do I track my order?",
            "answer": "Once your order is dispatched, you'll receive a tracking link via email and WhatsApp. You can also reach out to our support team anytime for a status update."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I change my size after ordering?",
            "answer": "Yes — contact us within 12 hours of placing your order and we'll arrange a size swap at no extra cost. Reach out via WhatsApp for the fastest response."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your return policy?",
            "answer": "We accept exchanges within 7 days of delivery for unworn items in original packaging. Contact our support team to initiate the process."
          }
        }
      ]
    }
  ]
}
{% endschema %}
