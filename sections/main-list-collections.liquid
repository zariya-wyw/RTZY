<section class="section section-tight collections-header">
  <div class="container">
    <h1 class="collections-title">All Collections</h1>
  </div>
</section>

{% for collection in collections %}
  {% if collection.products_count > 0 %}
    <section class="section section-tight" id="collection-{{ collection.handle }}">
      <div class="container section-head">
        <div>
          <p class="eyebrow">{{ collection.products_count }} pieces</p>
          <h2>{{ collection.title }}</h2>
        </div>
        <a class="text-link" href="{{ collection.url }}">View all →</a>
      </div>
      <div class="container">
        <div class="product-slider">
          {% for product in collection.products limit: 8 %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "Collections List",
  "settings": []
}
{% endschema %}
