<section class="section" id="lookbook">
  {% assign featured_collection = collections[section.settings.collection] | default: collections['summer-collection'] | default: collections['summer'] | default: collections.all %}
  <div class="container section-head">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <a class="text-link" href="{{ section.settings.view_all_link | default: featured_collection.url | default: routes.all_products_collection_url }}">View all →</a>
  </div>
  <div class="container">
    <div class="slider-wrapper featured-slider-shell">
      <button class="slider-arrow slider-arrow-left is-hidden" type="button" data-slider="featured-slider" data-dir="left" aria-label="Scroll left">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div id="featured-slider" class="product-slider featured-slider">
        {% for product in featured_collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
      <button class="slider-arrow slider-arrow-right" type="button" data-slider="featured-slider" data-dir="right" aria-label="Scroll right">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Summer edit"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Summer collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 16,
      "max": 24,
      "step": 1,
      "default": 16,
      "label": "Products to show"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
