<section class="section" id="lookbook">
  <div class="container section-head">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <a class="text-link" href="{{ section.settings.view_all_link | default: routes.all_products_collection_url }}">View all →</a>
  </div>
  <div class="container">
    <div class="slider-wrapper">
      <button class="slider-arrow slider-arrow-left is-hidden" type="button" data-slider="featured-grid" data-dir="left" aria-label="Scroll left">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div id="featured-grid" class="product-slider">
        {% assign featured_collection = collections[section.settings.collection] | default: collections.all %}
        {% for product in featured_collection.products limit: section.settings.products_to_show %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
      <button class="slider-arrow slider-arrow-right" type="button" data-slider="featured-grid" data-dir="right" aria-label="Scroll right">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  const arrows = document.querySelectorAll('[data-slider="featured-grid"]');
  const slider = document.getElementById('featured-grid');
  if (!arrows.length || !slider) return;

  function updateArrowVisibility() {
    const leftArrow = document.querySelector('[data-slider="featured-grid"][data-dir="left"]');
    const rightArrow = document.querySelector('[data-slider="featured-grid"][data-dir="right"]');
    if (!leftArrow || !rightArrow) return;
    leftArrow.classList.toggle('is-hidden', slider.scrollLeft <= 10);
    rightArrow.classList.toggle('is-hidden', slider.scrollLeft >= slider.scrollWidth - slider.clientWidth - 10);
  }

  slider.addEventListener('scroll', updateArrowVisibility, { passive: true });
  setTimeout(updateArrowVisibility, 500);

  arrows.forEach(arrow => {
    arrow.addEventListener('click', () => {
      const card = slider.querySelector('.product-card');
      const scrollAmount = card ? card.offsetWidth + 20 : 300;
      slider.scrollBy({ left: arrow.dataset.dir === 'left' ? -scrollAmount : scrollAmount, behavior: 'smooth' });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Latest drop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured selections"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
