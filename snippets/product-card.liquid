{%- comment -%}
  Product card — Premium glassmorphic design:
  - Ultra-luxury glass effect with backdrop blur
  - Hover: image carousel (cycles through images)
  - Brand name + product title + price with discount
  - Actions reveal on hover
{%- endcomment -%}
<article class="product-card" data-product-card>
  <a class="product-card-media" href="{{ product.url }}">
    {% if product.compare_at_price > product.price %}
      <div class="product-card-badge sale">SALE</div>
    {% elsif product.tags contains 'new' %}
      <div class="product-card-badge">NEW</div>
    {% endif %}
    <div class="product-card-art">
      {% for image in product.images %}
        <img 
          class="product-card-image{% if forloop.first %} is-active{% endif %}" 
          src="{{ image | image_url: width: 900 }}" 
          alt="{{ image.alt | default: product.title }}"
          loading="lazy"
          decoding="async"
          data-card-image
          data-index="{{ forloop.index0 }}"
        >
      {% endfor %}
      {% if product.images.size == 0 %}
        <div class="product-card-placeholder">
          <span>ZARIYA</span>
        </div>
      {% endif %}
    </div>
  </a>
  <div class="product-card-body">
    <p class="vendor">{{ product.vendor | default: 'ZARIYA' }}</p>
    <h3 class="product-title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <div class="price-row">
      {% if product.compare_at_price > product.price %}
        <span class="old-price">{{ product.compare_at_price | money }}</span>
      {% endif %}
      <span class="price">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
        <span class="discount-badge">{{ discount | round }}% OFF</span>
      {% endif %}
    </div>
    <div class="card-actions">
      <a class="button" href="{{ product.url }}">View</a>
      <button class="button button-solid" type="button" data-action="quick-add" data-product-id="{{ product.variants.first.id }}">Add to Bag</button>
    </div>
  </div>
</article>

<script>
  (function() {
    const card = document.currentScript.previousElementSibling;
    const images = card.querySelectorAll('[data-card-image]');
    
    if (images.length <= 1) return;
    
    let currentIndex = 0;
    let carouselInterval = null;
    
    function showImage(index) {
      images.forEach(img => img.classList.remove('is-active'));
      images[index % images.length].classList.add('is-active');
      currentIndex = (index + 1) % images.length;
    }
    
    function startCarousel() {
      if (carouselInterval) clearInterval(carouselInterval);
      carouselInterval = setInterval(() => {
        showImage(currentIndex);
      }, 2000);
    }
    
    function stopCarousel() {
      if (carouselInterval) {
        clearInterval(carouselInterval);
        carouselInterval = null;
      }
      images.forEach(img => img.classList.remove('is-active'));
      images[0].classList.add('is-active');
      currentIndex = 0;
    }
    
    card.addEventListener('mouseenter', startCarousel);
    card.addEventListener('mouseleave', stopCarousel);
    
    if (window.matchMedia('(hover: touch)').matches) {
      let touchStartTime = 0;
      card.addEventListener('touchstart', () => { touchStartTime = Date.now(); });
      card.addEventListener('touchend', () => {
        if (Date.now() - touchStartTime < 500) startCarousel();
      });
    }
  })();
</script>
