[
  {
    "name": "theme_info",
    "theme_name": "Zariya",
    "theme_version": "1.0.0",
    "theme_author": "Zariya",
    "theme_documentation_url": "https://zariya.com",
    "theme_support_url": "https://zariya.com/support"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image",
        "info": "Used in splash screen and header"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Shown in browser tab. Recommended: 32x32 PNG or SVG"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#fdf9f3"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#b08d57"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_whatsapp",
        "label": "WhatsApp number"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_drawer_enabled",
        "label": "Enable cart drawer",
        "default": true
      }
    ]
  }
]
